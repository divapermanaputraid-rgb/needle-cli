{
  "name": "needle-cli",
  "version": "0.1.0",
  "description": "Needle — open-source, multi-provider AI coding CLI",
  "main": "./dist/index.js",
  "type": "module",
  "bin": {
    "needle": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json",
    "assets/logo.png"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx src/cli/index.ts",
    "build": "tsup src/cli/index.ts --format esm --dts --clean --no-sourcemap",
    "typecheck": "tsc --noEmit",
    "package:audit": "node scripts/package-audit.mjs",
    "prepack": "pnpm build && pnpm package:audit",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "glob": "^13.0.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "tsup": "^8.0.2",
    "tsx": "^4.10.5",
    "typescript": "^5.4.5"
  }
}
